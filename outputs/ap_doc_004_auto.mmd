  n8["the invoice is routed for director approval.\n[ROUTE_FOR_REVIEW]"]
  n9{"Decision\n<APPROVE_OR_REJECT>"}
  n10["the invoice is scheduled for payment.\n[SCHEDULE_PAYMENT]"]
  n11([["End"]])
